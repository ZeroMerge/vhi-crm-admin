PORT=5000
NODE_ENV=development

# Local or Supabase Postgres connection string
DATABASE_URL=postgresql://postgres:<your-db-password>@localhost:5432/vhi_crm

# Backend-only secrets
ADMIN_JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Local frontend during dev
FRONTEND_URL=http://localhost:5173

# Optional service credentials
PAYSTACK_SECRET_KEY=sk_test_xxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# Production example:
# FRONTEND_URL=https://vhi-crm-admin.vercel.app/
# DATABASE_URL=postgresql://postgres:<your-db-password>@db.cfofpvigvetdnodtylys.supabase.co:5432/postgres